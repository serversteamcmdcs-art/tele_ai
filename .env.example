# TeleAI Environment Variables
# Copy this file to .env and fill in the values

# Server
NODE_ENV=development
PORT=3001

# JWT Secret (generate a secure random string for production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Database (SQLite)
# For local development:
DATABASE_URL="file:./packages/server/data/teleai.db"
# For Render production (auto-set by render.yaml):
# DATABASE_URL="file:/opt/render/project/data/teleai.db"
